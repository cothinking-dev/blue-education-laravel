        <mxCell id="55" value="§8 · TESTIMONIALS — 3 of 5 visible (carousel)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#bfdbfe;fontColor=#1d4ed8;fontSize=8;fontStyle=1;align=left;verticalAlign=middle;spacingLeft=6;" vertex="1" parent="1">
