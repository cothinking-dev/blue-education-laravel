        <mxCell id="27" value="§4 · WHAT WE DO — 2×2 Bento Grid" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#bfdbfe;fontColor=#1d4ed8;fontSize=8;fontStyle=1;align=left;verticalAlign=middle;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="0" y="630" width="195" height="14" as="geometry" />
        </mxCell>
        <!-- Section title -->
        <mxCell id="28" value="What We Do" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=18;fontStyle=1;fontColor=#111827;" vertex="1" parent="1">
          <mxGeometry x="40" y="656" width="300" height="42" as="geometry" />
        </mxCell>
        <!-- Card 1: Education Services -->
        <mxCell id="29" value="[icon]&#xa;&#xa;Education Services&#xa;&#xa;Primary school to PhD. We help you find the right institution and program for your goals.&#xa;&#xa;Explore education pathways →" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#f9fafb;strokeColor=#e5e7eb;fontSize=10;align=left;spacingLeft=14;spacingTop=12;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="40" y="718" width="570" height="165" as="geometry" />
        </mxCell>
        <!-- Card 2: Migration & Visas -->
        <mxCell id="30" value="[icon]&#xa;&#xa;Migration &amp; Visas&#xa;&#xa;Not sure which visa you need? We'll assess your situation and help you handle the application.&#xa;&#xa;See visa options →" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#f9fafb;strokeColor=#e5e7eb;fontSize=10;align=left;spacingLeft=14;spacingTop=12;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="670" y="718" width="570" height="165" as="geometry" />
        </mxCell>
        <!-- Card 3: Career Services -->
        <mxCell id="31" value="[icon]&#xa;&#xa;Career Services&#xa;&#xa;We help graduates build a career in Australia. Your Australian qualification is only useful if you can work with it.&#xa;&#xa;Build your career →" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#f9fafb;strokeColor=#e5e7eb;fontSize=10;align=left;spacingLeft=14;spacingTop=12;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="40" y="903" width="570" height="167" as="geometry" />
        </mxCell>
        <!-- Card 4: Student Support -->
        <mxCell id="32" value="[icon]&#xa;&#xa;Student Support&#xa;&#xa;We cover everything a student needs. Accommodation, guardianship, health cover, airport transfers, and a 24/7 emergency line.&#xa;&#xa;See support services →" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#f9fafb;strokeColor=#e5e7eb;fontSize=10;align=left;spacingLeft=14;spacingTop=12;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="670" y="903" width="570" height="167" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════
             §5  HOW WE CARE   y=1110  h=400  →  end=1510
        ═══════════════════════════════════════════════════════ -->
        <mxCell id="33" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f9fafb;strokeColor=#e5e7eb;" vertex="1" parent="1">
          <mxGeometry x="0" y="1110" width="1280" height="400" as="geometry" />
        </mxCell>
        <mxCell id="34" value="§5 · HOW WE CARE — 60/40 Two-Column" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#bfdbfe;fontColor=#1d4ed8;fontSize=8;fontStyle=1;align=left;verticalAlign=middle;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="0" y="1110" width="210" height="14" as="geometry" />
        </mxCell>
        <!-- Left text column (60%) -->
        <mxCell id="35" value="28 years of experience we stand behind.&#xa;&#xa;Since 1998, we've operated on one principle: give honest advice.&#xa;&#xa;Every client is assigned a dedicated advisor who coordinates your education, visa, and career plan — start to finish. No handoffs between agencies means no need to re-explain your situation over and over again.&#xa;&#xa;That means telling you when a visa application won't succeed, a course isn't the right fit, or a better path exists — before you commit to the wrong one.&#xa;&#xa;That's earned the trust of clients from 40+ countries — scholars who came back, and brought others — for decisions that shaped their lives.&#xa;&#xa;Learn our story →" style="text;html=0;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=10;fontColor=#374151;" vertex="1" parent="1">
          <mxGeometry x="40" y="1140" width="700" height="350" as="geometry" />
        </mxCell>
        <!-- Right image placeholder (40%) -->
        <mxCell id="36" value="[IMAGE: Glen in consultation with a student]" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#d1d5db;strokeColor=#9ca3af;fontColor=#6b7280;fontSize=11;fontStyle=2;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="780" y="1125" width="460" height="365" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════
             §6  FEATURED PROGRAMS   y=1510  h=420  →  end=1930
        ═══════════════════════════════════════════════════════ -->
        <mxCell id="37" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#e5e7eb;" vertex="1" parent="1">
          <mxGeometry x="0" y="1510" width="1280" height="420" as="geometry" />
        </mxCell>
        <mxCell id="38" value="§6 · FEATURED PROGRAMS — 2 Horizontal Cards" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#bfdbfe;fontColor=#1d4ed8;fontSize=8;fontStyle=1;align=left;verticalAlign=middle;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="0" y="1510" width="240" height="14" as="geometry" />
        </mxCell>
        <!-- Section title -->
        <mxCell id="39" value="Featured Programs" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=18;fontStyle=1;fontColor=#111827;" vertex="1" parent="1">
          <mxGeometry x="40" y="1538" width="280" height="42" as="geometry" />
        </mxCell>
        <!-- Card 1 image: Buddy Programme -->
        <mxCell id="40" value="[IMAGE: Students in school uniform with Australian buddies, classroom]" style="rounded=0;whiteSpace=wrap;html=0;fillColor=#d1d5db;strokeColor=#9ca3af;fontColor=#6b7280;fontSize=10;fontStyle=2;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="1598" width="570" height="180" as="geometry" />
        </mxCell>
        <!-- Card 1 text body -->
        <mxCell id="41" value="[TAG: 14-Day Immersion]&#xa;&#xa;Buddy Programme&#xa;&#xa;14 days at an Australian homestay — classroom integration and cultural immersion. Built in partnership with Anglican Schools.&#xa;&#xa;Discover the Buddy Programme →" style="rounded=0;whiteSpace=wrap;html=0;fillColor=#f9fafb;strokeColor=#e5e7eb;fontSize=10;align=left;spacingLeft=12;spacingTop=10;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="40" y="1778" width="570" height="132" as="geometry" />
        </mxCell>
        <!-- Card 2 image: SCSA Associate -->
        <mxCell id="42" value="[IMAGE: Students in graduation attire, WA landscape]" style="rounded=0;whiteSpace=wrap;html=0;fillColor=#d1d5db;strokeColor=#9ca3af;fontColor=#6b7280;fontSize=10;fontStyle=2;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="670" y="1598" width="570" height="180" as="geometry" />
        </mxCell>
        <!-- Card 2 text body -->
        <mxCell id="43" value="[TAG: International Curriculum]&#xa;&#xa;SCSA Associate&#xa;&#xa;Complete the Western Australian Certificate of Education (WACE) from your home country. Officially recognised and globally respected.&#xa;&#xa;Learn about SCSA →" style="rounded=0;whiteSpace=wrap;html=0;fillColor=#f9fafb;strokeColor=#e5e7eb;fontSize=10;align=left;spacingLeft=12;spacingTop=10;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="670" y="1778" width="570" height="132" as="geometry" />
        </mxCell>
        <!-- See all programmes link -->
        <mxCell id="44" value="See all programmes →" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=12;fontColor=#2563eb;" vertex="1" parent="1">
          <mxGeometry x="540" y="1918" width="200" height="24" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════
             §7  WHY WESTERN AUSTRALIA   y=1930  h=490  →  end=2420
        ═══════════════════════════════════════════════════════ -->
        <mxCell id="45" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f9fafb;strokeColor=#e5e7eb;" vertex="1" parent="1">
          <mxGeometry x="0" y="1930" width="1280" height="490" as="geometry" />
        </mxCell>
        <mxCell id="46" value="§7 · WHY WESTERN AUSTRALIA — 5-Card Bento Grid" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#bfdbfe;fontColor=#1d4ed8;fontSize=8;fontStyle=1;align=left;verticalAlign=middle;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="0" y="1930" width="268" height="14" as="geometry" />
        </mxCell>
        <!-- Section title -->
        <mxCell id="47" value="Why Western Australia" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=18;fontStyle=1;fontColor=#111827;" vertex="1" parent="1">
          <mxGeometry x="40" y="1958" width="340" height="42" as="geometry" />
        </mxCell>
        <!-- Row 1: Large card (2/3 width) -->
        <mxCell id="48" value="Perth regularly features among the world's most liveable cities.&#xa;&#xa;Clean air, short commutes, a safe city, and a genuinely multicultural community. Students who come here tend to stay." style="rounded=1;whiteSpace=wrap;html=0;fillColor=#ffffff;strokeColor=#e5e7eb;fontSize=10;align=left;spacingLeft=14;spacingTop=12;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="40" y="2015" width="780" height="180" as="geometry" />
        </mxCell>
        <!-- Row 1: Small card (1/3 width) -->
        <mxCell id="49" value="Four globally recognised universities. All in Perth.&#xa;&#xa;UWA, Curtin, Murdoch, and ECU offer qualifications accepted by employers and institutions in every major market." style="rounded=1;whiteSpace=wrap;html=0;fillColor=#ffffff;strokeColor=#e5e7eb;fontSize=10;align=left;spacingLeft=14;spacingTop=12;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="840" y="2015" width="400" height="180" as="geometry" />
        </mxCell>
        <!-- Row 2: Card A -->
        <mxCell id="50" value="Your degree comes with time to use it.&#xa;&#xa;Graduates receive 2-4 years of unrestricted work rights — enough to build real experience, establish connections, and weigh your options properly." style="rounded=1;whiteSpace=wrap;html=0;fillColor=#ffffff;strokeColor=#e5e7eb;fontSize=10;align=left;spacingLeft=14;spacingTop=12;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="40" y="2215" width="373" height="170" as="geometry" />
        </mxCell>
        <!-- Row 2: Card B -->
        <mxCell id="51" value="A job market that needs skilled graduates.&#xa;&#xa;Western Australia's resources, healthcare, construction, and professional services sectors are all expanding. The demand for qualified people is genuine and growing." style="rounded=1;whiteSpace=wrap;html=0;fillColor=#ffffff;strokeColor=#e5e7eb;fontSize=10;align=left;spacingLeft=14;spacingTop=12;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="433" y="2215" width="373" height="170" as="geometry" />
        </mxCell>
        <!-- Row 2: Card C -->
        <mxCell id="52" value="One curriculum. K to PhD.&#xa;&#xa;WA's SCSA-governed framework covers every stage — from primary school through to doctoral research. Structured, regulated, and recognised internationally." style="rounded=1;whiteSpace=wrap;html=0;fillColor=#ffffff;strokeColor=#e5e7eb;fontSize=10;align=left;spacingLeft=14;spacingTop=12;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="826" y="2215" width="414" height="170" as="geometry" />
        </mxCell>
        <!-- Link -->
        <mxCell id="53" value="See why Western Australia →" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12;fontColor=#2563eb;" vertex="1" parent="1">
          <mxGeometry x="40" y="2402" width="260" height="24" as="geometry" />
        </mxCell>

