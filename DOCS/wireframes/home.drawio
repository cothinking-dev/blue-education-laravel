        <!-- Section title -->
        <mxCell id="56" value="What Our Clients Say" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=18;fontStyle=1;fontColor=#111827;" vertex="1" parent="1">
          <mxGeometry x="40" y="2448" width="340" height="42" as="geometry" />
        </mxCell>
        <!-- Testimonial 1 -->
        <mxCell id="57" value="&quot;The team went above and beyond, helping me find my course of interest and arrange a scholarship to UWA within 2 weeks.&quot;&#xa;&#xa;— N.L. · Malaysia&#xa;Bachelor of Commerce, UWA" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#f9fafb;strokeColor=#e5e7eb;fontSize=10;align=left;spacingLeft=14;spacingTop=12;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="40" y="2510" width="373" height="185" as="geometry" />
        </mxCell>
        <!-- Testimonial 2 -->
        <mxCell id="58" value="&quot;Where would I be without the team at Blue Education? They have helped me so much through my time in Perth, that they are now like family. They are always there for me, whatever I need.&quot;&#xa;&#xa;— H.T. · Japan&#xa;MBA, Curtin University" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#f9fafb;strokeColor=#e5e7eb;fontSize=10;align=left;spacingLeft=14;spacingTop=12;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="433" y="2510" width="373" height="185" as="geometry" />
        </mxCell>
        <!-- Testimonial 3 -->
        <mxCell id="59" value="&quot;Blue Education made my dream of becoming a Registered Nurse come true.&quot;&#xa;&#xa;— S.W. · Singapore&#xa;Bachelor of Nursing, ECU" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#f9fafb;strokeColor=#e5e7eb;fontSize=10;align=left;spacingLeft=14;spacingTop=12;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="826" y="2510" width="414" height="185" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════
             §9  PARTNERS   y=2720  h=140  →  end=2860
